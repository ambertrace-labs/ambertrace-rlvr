# ambertrace-rlvr — environment configuration
# Copy to .env and fill in. .env is gitignored; never commit real keys.

# AmberTrace verified platform credentials (public SDK: `pip install ambertraceai`).
# Use a SCOPED, PLATFORM-ONLY key for training jobs — never a full-account key.
AMBERTRACE_API_KEY=

# AmberTrace API base URL (default shown).
AMBERTRACE_BASE_URL=https://app.ambertrace.ai

# The verified platform this run trains against (e.g. plat_acmg_variant_v3).
AMBERTRACE_PLATFORM_ID=
